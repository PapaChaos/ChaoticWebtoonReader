@page "/"
@using System.Globalization
@implements IDisposable
@inject ReaderLibraryService Reader
@inject PatreonAuthService Patreon
@inject IJSRuntime JS

<div class="@AppShellClass">
    <aside class="source-panel">
        <div class="brand">
            <span class="brand-mark">JWR</span>
            <div>
                <div class="brand-title">Jank Webtoon Reader</div>
                <div class="brand-subtitle">Windows + Android client</div>
            </div>
        </div>

        <section class="panel">
            <div class="panel-title">Open Comic</div>
            <button type="button" class="primary-action" @onclick="OpenPickedArchiveAsync" disabled="@_isBusy">
                Open zip / cbz
            </button>
            <div class="hint">Works on Windows and Android through the system file picker.</div>
        </section>

        <section class="panel">
            <label for="source-path" class="panel-title">Path or URL</label>
            <input id="source-path"
                   @bind="_sourcePath"
                   @bind:event="oninput"
                   placeholder="C:\Comics\Series or Google Drive / zip URL"
                   disabled="@_isBusy" />
            <button type="button" @onclick="OpenPathAsync" disabled="@_isBusy">Open path</button>
            <div class="hint">Windows folder paths, zip/cbz paths, direct zip URLs, and public Google Drive file links.</div>
        </section>

        <section class="panel cache-panel">
            <div class="panel-title">Offline cache</div>
            <div class="cache-summary">
                <strong>@_cacheSizeLabel</strong>
                <span>@_cacheCountLabel</span>
            </div>
            <button type="button" @onclick="ClearCacheAsync" disabled="@(_cacheBusy || _isBusy)">
                Clear cached downloads
            </button>
            <div class="hint">Downloaded comics stay available offline until cleared. The open comic is kept.</div>
        </section>

        <section class="panel patreon-panel">
            <div class="panel-title">Patreon</div>

            @if (_patreonState is null)
            {
                <div class="hint">Loading Patreon account...</div>
            }
            else if (_patreonState.IsConnected)
            {
                <div class="account-card">
                    <strong>@(_patreonState.DisplayName ?? "Patreon member")</strong>
                    <span>@(_patreonState.Memberships.Count) membership(s)</span>
                </div>

                @if (_patreonState.Memberships.Count > 0)
                {
                    <div class="membership-list">
                        @foreach (var membership in _patreonState.Memberships)
                        {
                            <div class="membership-item">
                                <strong>@membership.CampaignName</strong>
                                <span>@(membership.PatronStatus ?? "unknown")</span>
                                @if (membership.Tiers.Count > 0)
                                {
                                    <div class="tier-list">
                                        @foreach (var tier in membership.Tiers)
                                        {
                                            <span>@tier.Title</span>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="hint">Not connected.</div>
            }

            <details class="settings-block">
                <summary>OAuth settings</summary>
                <label for="patreon-client-id">Client ID</label>
                <input id="patreon-client-id"
                       @bind="_patreonClientId"
                       @bind:event="oninput"
                       placeholder="Patreon OAuth client ID"
                       disabled="@_patreonBusy" />

                <label for="patreon-client-secret">Client secret</label>
                <input id="patreon-client-secret"
                       type="password"
                       @bind="_patreonClientSecret"
                       @bind:event="oninput"
                       placeholder="@ClientSecretPlaceholder"
                       disabled="@_patreonBusy" />

                <label for="patreon-redirect-uri">Redirect URI</label>
                <input id="patreon-redirect-uri"
                       @bind="_patreonRedirectUri"
                       @bind:event="oninput"
                       disabled="@_patreonBusy" />

                <button type="button" @onclick="SavePatreonSettingsAsync" disabled="@_patreonBusy">
                    Save Patreon settings
                </button>
                <div class="hint">Register this redirect URI in your Patreon OAuth client.</div>
            </details>

            <div class="button-row">
                <button type="button" @onclick="ConnectPatreonAsync" disabled="@_patreonBusy">Connect</button>
                <button type="button" @onclick="RefreshPatreonAsync" disabled="@_patreonBusy">Refresh</button>
                <button type="button" @onclick="DisconnectPatreonAsync" disabled="@_patreonBusy">Disconnect</button>
            </div>

            @if (!string.IsNullOrWhiteSpace(_patreonStatus))
            {
                <div class="status @(_patreonError ? "error" : null)">@_patreonStatus</div>
            }
        </section>

        <section class="panel reader-controls-panel">
            <div class="panel-title">Reader</div>
            <div class="segmented-control" role="group" aria-label="Reading mode">
                <button type="button"
                        class="@ReaderModeButtonClass(ReaderViewMode.Vertical)"
                        @onclick="() => SetReaderModeAsync(ReaderViewMode.Vertical)">
                    Vertical
                </button>
                <button type="button"
                        class="@ReaderModeButtonClass(ReaderViewMode.Japanese)"
                        @onclick="() => SetReaderModeAsync(ReaderViewMode.Japanese)">
                    Japanese
                </button>
                <button type="button"
                        class="@ReaderModeButtonClass(ReaderViewMode.Western)"
                        @onclick="() => SetReaderModeAsync(ReaderViewMode.Western)">
                    Western
                </button>
            </div>

            <div class="zoom-controls">
                <button type="button" @onclick="() => ChangeZoom(-ZoomStep)" disabled="@(_manifest is null)" aria-label="Zoom out">-</button>
                <input type="range"
                       min="@MinZoom"
                       max="@MaxZoom"
                       step="@ZoomStep"
                       value="@_zoomPercent"
                       @oninput="OnZoomInput"
                       disabled="@(_manifest is null)"
                       aria-label="Reader zoom" />
                <button type="button" @onclick="() => ChangeZoom(ZoomStep)" disabled="@(_manifest is null)" aria-label="Zoom in">+</button>
                <span>@_zoomPercent%</span>
            </div>

            <div class="button-row two-up">
                <button type="button" @onclick="ResetZoom" disabled="@(_manifest is null)">Reset zoom</button>
                <button type="button" @onclick="ToggleFullscreenAsync" disabled="@(_manifest is null)">
                    @FullscreenButtonText
                </button>
            </div>
        </section>

        @if (_manifest is not null)
        {
            <section class="panel page-panel">
                <div class="panel-title">Pages</div>
                <div class="page-list">
                    @foreach (var page in _pages)
                    {
                        <a href="@($"#page-{page.Index}")"
                           class="@PageLinkClass(page.Index)"
                           @onclick="() => ScrollToPageAsync(page.Index)"
                           @onclick:preventDefault="true">
                            <span>@(page.Index + 1)</span>
                            <span>@(page.Name)</span>
                        </a>
                    }
                </div>
            </section>
        }

        @if (!string.IsNullOrWhiteSpace(_status))
        {
            <div class="status @(_isError ? "error" : null)">@_status</div>
        }
    </aside>

    <main class="reader-shell">
        <header class="reader-header">
            <div>
                <h1>@(_manifest?.Title ?? "Open a comic")</h1>
                <p>@ReaderSummary</p>
            </div>
            @if (_manifest is not null)
            {
                <div class="reader-header-actions">
                    <button type="button" @onclick="() => NavigatePageAsync(-1)" disabled="@(!CanNavigateBackward)">Prev</button>
                    <span>@($"{_currentPageIndex + 1} / {_pages.Count}")</span>
                    <button type="button" @onclick="() => NavigatePageAsync(1)" disabled="@(!CanNavigateForward)">Next</button>
                </div>
            }
        </header>

        @if (_isFullscreen)
        {
            <div class="reader-floating-toolbar">
                <button type="button" @onclick="ToggleFullscreenAsync">Exit</button>
                <button type="button" @onclick="() => NavigatePageAsync(-1)" disabled="@(!CanNavigateBackward)">Prev</button>
                <span>@(_pages.Count == 0 ? "0 / 0" : $"{_currentPageIndex + 1} / {_pages.Count}")</span>
                <button type="button" @onclick="() => NavigatePageAsync(1)" disabled="@(!CanNavigateForward)">Next</button>
                <button type="button" @onclick="() => ChangeZoom(-ZoomStep)" disabled="@(_manifest is null)" aria-label="Zoom out">-</button>
                <span>@_zoomPercent%</span>
                <button type="button" @onclick="() => ChangeZoom(ZoomStep)" disabled="@(_manifest is null)" aria-label="Zoom in">+</button>
            </div>
        }

        <section class="@ReaderClass" style="@ReaderStyle">
            @if (_manifest is null)
            {
                <div class="empty-state">
                    <strong>No comic loaded.</strong>
                    <span>Open a zip, cbz, folder path, or direct zip URL to start reading.</span>
                </div>
            }
            else
            {
                @foreach (var page in _pages)
                {
                    <article id="@($"page-{page.Index}")" class="reader-page">
                        @if (page.ImageSource is null)
                        {
                            <div class="page-loading">Loading @(page.Index + 1)</div>
                        }
                        else
                        {
                            <img src="@(page.ImageSource)" alt="@(page.Name)" />
                        }
                    </article>
                }
            }
        </section>
    </main>
</div>

@code {
    private string _sourcePath = string.Empty;
    private string _status = string.Empty;
    private bool _isBusy;
    private bool _isError;
    private ComicManifest? _manifest;
    private List<PageViewModel> _pages = [];
    private int _loadVersion;
    private string _cacheSizeLabel = "Checking...";
    private string _cacheCountLabel = "Cache";
    private bool _cacheBusy;
    private PatreonSettingsState? _patreonSettings;
    private PatreonAccountState? _patreonState;
    private string _patreonClientId = string.Empty;
    private string _patreonClientSecret = string.Empty;
    private string _patreonRedirectUri = string.Empty;
    private string _patreonStatus = string.Empty;
    private bool _patreonBusy;
    private bool _patreonError;
    private ReaderViewMode _readerMode = ReaderViewMode.Vertical;
    private int _zoomPercent = 100;
    private int _currentPageIndex;
    private bool _isFullscreen;
    private DotNetObjectReference<Home>? _dotNetReference;

    private const int MinZoom = 50;
    private const int MaxZoom = 250;
    private const int ZoomStep = 10;

    private string ReaderSummary
        => _manifest is null
            ? "Zip, cbz, folder path, or direct zip URL."
            : $"{_manifest.PageCount} pages from {_manifest.SourceType}";

    private string ClientSecretPlaceholder
        => _patreonSettings?.HasClientSecret == true
            ? "Stored. Leave blank to keep it."
            : "Patreon OAuth client secret";

    private string AppShellClass
        => _isFullscreen ? "app-shell is-reader-fullscreen" : "app-shell";

    private string ReaderClass
        => $"reader {ReaderModeClass}";

    private string ReaderModeClass
        => _readerMode switch
        {
            ReaderViewMode.Japanese => "mode-paged-rtl",
            ReaderViewMode.Western => "mode-paged-ltr",
            _ => "mode-vertical"
        };

    private string ReaderStyle
        => $"--reader-zoom: {(_zoomPercent / 100d).ToString("0.##", CultureInfo.InvariantCulture)};";

    private string FullscreenButtonText
        => _isFullscreen ? "Exit fullscreen" : "Fullscreen";

    private bool CanNavigateBackward
        => _pages.Count > 0 && _currentPageIndex > 0;

    private bool CanNavigateForward
        => _pages.Count > 0 && _currentPageIndex < _pages.Count - 1;

    protected override async Task OnInitializedAsync()
    {
        await LoadCacheStateAsync();
        await LoadPatreonStateAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return;
        }

        _dotNetReference = DotNetObjectReference.Create(this);

        try
        {
            await JS.InvokeVoidAsync("jankReader.initialize", _dotNetReference);
        }
        catch (JSException)
        {
            // The reader still works with the on-screen controls if shortcut wiring fails.
        }
    }

    private async Task OpenPickedArchiveAsync()
    {
        await RunOpenAsync(async () =>
        {
            var manifest = await Reader.PickArchiveAsync();
            await UseManifestAsync(manifest);
        });
    }

    private async Task OpenPathAsync()
    {
        if (string.IsNullOrWhiteSpace(_sourcePath))
        {
            SetStatus("Enter a folder path, zip/cbz path, or direct zip URL.", true);
            return;
        }

        await RunOpenAsync(async () =>
        {
            var manifest = await Reader.OpenSourceAsync(_sourcePath);
            await UseManifestAsync(manifest);
        });
    }

    private async Task RunOpenAsync(Func<Task> action)
    {
        _isBusy = true;
        SetStatus("Opening comic...");

        try
        {
            await action();
        }
        catch (OperationCanceledException)
        {
            SetStatus("Open canceled.");
        }
        catch (ReaderSourceException ex)
        {
            SetStatus(ex.Message, true);
        }
        catch (Exception ex)
        {
            SetStatus($"Could not open comic: {ex.Message}", true);
        }
        finally
        {
            _isBusy = false;
            await LoadCacheStateAsync();
        }
    }

    private async Task UseManifestAsync(ComicManifest manifest)
    {
        _loadVersion++;
        var loadVersion = _loadVersion;

        _manifest = manifest;
        _currentPageIndex = 0;
        _pages = manifest.Pages
            .Select(page => new PageViewModel(page.Index, page.Name))
            .ToList();

        SetStatus($"Found {manifest.PageCount} pages. Loading images...");
        await InvokeAsync(StateHasChanged);

        foreach (var page in _pages)
        {
            if (loadVersion != _loadVersion)
            {
                return;
            }

            page.ImageSource = await Reader.LoadPageDataUrlAsync(page.Index);
            SetStatus($"Loaded page {page.Index + 1} of {manifest.PageCount}.");
            await InvokeAsync(StateHasChanged);
        }

        SetStatus($"Ready: {manifest.PageCount} pages.");
        await ScrollToPageAsync(0);
    }

    private void SetStatus(string message, bool isError = false)
    {
        _status = message;
        _isError = isError;
    }

    private async Task LoadCacheStateAsync()
    {
        var state = await Reader.GetCacheStateAsync();
        _cacheSizeLabel = FormatBytes(state.TotalBytes);
        _cacheCountLabel = state.ArchiveCount == 1
            ? "1 cached comic"
            : $"{state.ArchiveCount} cached comics";
    }

    private async Task ClearCacheAsync()
    {
        _cacheBusy = true;

        try
        {
            var state = await Reader.ClearCacheAsync();
            _cacheSizeLabel = FormatBytes(state.TotalBytes);
            _cacheCountLabel = state.ArchiveCount == 1
                ? "1 cached comic"
                : $"{state.ArchiveCount} cached comics";
            SetStatus("Cached downloads cleared. The open comic was kept.");
        }
        catch (Exception ex)
        {
            SetStatus($"Could not clear cache: {ex.Message}", true);
        }
        finally
        {
            _cacheBusy = false;
        }
    }

    private static string FormatBytes(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        var value = (double)bytes;
        var unitIndex = 0;

        while (value >= 1024 && unitIndex < units.Length - 1)
        {
            value /= 1024;
            unitIndex++;
        }

        return unitIndex == 0
            ? $"{bytes} {units[unitIndex]}"
            : $"{value:0.#} {units[unitIndex]}";
    }

    private async Task LoadPatreonStateAsync()
    {
        _patreonSettings = await Patreon.GetSettingsAsync();
        _patreonClientId = _patreonSettings.ClientId;
        _patreonRedirectUri = _patreonSettings.RedirectUri;
        _patreonState = await Patreon.GetAccountStateAsync();
    }

    private async Task SavePatreonSettingsAsync()
    {
        await RunPatreonAsync("Saving Patreon settings...", async () =>
        {
            await Patreon.SaveSettingsAsync(_patreonClientId, _patreonClientSecret, _patreonRedirectUri);
            _patreonClientSecret = string.Empty;
            await LoadPatreonStateAsync();
            SetPatreonStatus("Patreon settings saved.");
        });
    }

    private async Task ConnectPatreonAsync()
    {
        await RunPatreonAsync("Opening Patreon login...", async () =>
        {
            _patreonState = await Patreon.ConnectAsync();
            _patreonSettings = await Patreon.GetSettingsAsync();
            SetPatreonStatus("Patreon connected.");
        });
    }

    private async Task RefreshPatreonAsync()
    {
        await RunPatreonAsync("Refreshing Patreon account...", async () =>
        {
            _patreonState = await Patreon.RefreshAccountAsync();
            SetPatreonStatus("Patreon account refreshed.");
        });
    }

    private async Task DisconnectPatreonAsync()
    {
        await RunPatreonAsync("Disconnecting Patreon...", async () =>
        {
            await Patreon.DisconnectAsync();
            await LoadPatreonStateAsync();
            SetPatreonStatus("Patreon disconnected.");
        });
    }

    private async Task RunPatreonAsync(string busyMessage, Func<Task> action)
    {
        _patreonBusy = true;
        SetPatreonStatus(busyMessage);

        try
        {
            await action();
        }
        catch (OperationCanceledException)
        {
            SetPatreonStatus("Patreon login canceled.");
        }
        catch (PatreonAuthException ex)
        {
            SetPatreonStatus(ex.Message, true);
        }
        catch (Exception ex)
        {
            SetPatreonStatus($"Patreon failed: {ex.Message}", true);
        }
        finally
        {
            _patreonBusy = false;
        }
    }

    private void SetPatreonStatus(string message, bool isError = false)
    {
        _patreonStatus = message;
        _patreonError = isError;
    }

    private string ReaderModeButtonClass(ReaderViewMode mode)
        => _readerMode == mode ? "active" : string.Empty;

    private string PageLinkClass(int pageIndex)
        => _currentPageIndex == pageIndex ? "page-link active" : "page-link";

    private async Task SetReaderModeAsync(ReaderViewMode mode)
    {
        _readerMode = mode;
        await InvokeAsync(StateHasChanged);
        await ScrollToPageAsync(_currentPageIndex);
    }

    private async Task ToggleFullscreenAsync()
    {
        _isFullscreen = !_isFullscreen;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (_isFullscreen)
            {
                await JS.InvokeVoidAsync("jankReader.requestFullscreen", ".app-shell");
            }
            else
            {
                await JS.InvokeVoidAsync("jankReader.exitFullscreen");
            }
        }
        catch (JSException)
        {
            // CSS fullscreen still works if the WebView refuses the browser fullscreen API.
        }

        await ScrollToPageAsync(_currentPageIndex);
    }

    private void OnZoomInput(ChangeEventArgs args)
    {
        if (int.TryParse(Convert.ToString(args.Value, CultureInfo.InvariantCulture), out var zoom))
        {
            SetZoom(zoom);
        }
    }

    private void ChangeZoom(int delta)
    {
        SetZoom(_zoomPercent + delta);
    }

    private void ResetZoom()
    {
        SetZoom(100);
    }

    private void SetZoom(int zoom)
    {
        _zoomPercent = Math.Clamp(zoom, MinZoom, MaxZoom);
    }

    [JSInvokable]
    public async Task ChangeZoomFromShortcutAsync(int delta)
    {
        if (delta == 0)
        {
            ResetZoom();
        }
        else
        {
            ChangeZoom(delta);
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task NavigateHorizontalFromShortcutAsync(int physicalDirection)
    {
        var delta = _readerMode == ReaderViewMode.Japanese
            ? -physicalDirection
            : physicalDirection;

        await NavigatePageAsync(delta);
    }

    [JSInvokable]
    public async Task ToggleFullscreenFromShortcutAsync()
    {
        if (_manifest is null)
        {
            return;
        }

        await ToggleFullscreenAsync();
    }

    [JSInvokable]
    public async Task ExitFullscreenFromShortcutAsync()
    {
        if (!_isFullscreen)
        {
            return;
        }

        await ToggleFullscreenAsync();
    }

    [JSInvokable]
    public async Task SetReaderModeFromShortcutAsync(string mode)
    {
        if (_manifest is null)
        {
            return;
        }

        var nextMode = mode switch
        {
            "japanese" => ReaderViewMode.Japanese,
            "western" => ReaderViewMode.Western,
            _ => ReaderViewMode.Vertical
        };

        await SetReaderModeAsync(nextMode);
    }

    private async Task NavigatePageAsync(int delta)
    {
        if (_pages.Count == 0)
        {
            return;
        }

        var nextIndex = Math.Clamp(_currentPageIndex + delta, 0, _pages.Count - 1);
        await ScrollToPageAsync(nextIndex);
    }

    private async Task ScrollToPageAsync(int pageIndex)
    {
        if (_pages.Count == 0)
        {
            _currentPageIndex = 0;
            return;
        }

        _currentPageIndex = Math.Clamp(pageIndex, 0, _pages.Count - 1);
        await InvokeAsync(StateHasChanged);

        try
        {
            await JS.InvokeVoidAsync("jankReader.scrollToPage", _currentPageIndex);
        }
        catch (JSException)
        {
            // The anchor still exists; failing to animate is not fatal.
        }
    }

    private enum ReaderViewMode
    {
        Vertical,
        Japanese,
        Western
    }

    public void Dispose()
    {
        _dotNetReference?.Dispose();
    }

    private sealed class PageViewModel(int index, string name)
    {
        public int Index { get; } = index;
        public string Name { get; } = name;
        public string? ImageSource { get; set; }
    }
}
